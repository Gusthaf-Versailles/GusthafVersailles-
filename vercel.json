{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/inicio",
      "permanent": false
    },
    {
      "source": "/Projects/ElegantFonts/index.html",
      "destination": "/elegant-fonts",
      "permanent": true
    },
    {
      "source": "/Projects/FontPairing/index.html",
      "destination": "/font-pairing",
      "permanent": true
    },
    {
      "source": "/Projects/AtelierNoir/index.html",
      "destination": "/atelier-noir",
      "permanent": true
    },
    {
      "source": "/Projects/ElegantFonts/footer/sobre.html",
      "destination": "/elegant-fonts/sobre",
      "permanent": true
    },
    {
      "source": "/Projects/ElegantFonts/footer/privacidade.html",
      "destination": "/elegant-fonts/privacidade",
      "permanent": true
    },
    {
      "source": "/Projects/ElegantFonts/footer/contato.html",
      "destination": "/elegant-fonts/contato",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/inicio",
      "destination": "/index.html"
    },
    {
      "source": "/sobre",
      "destination": "/index.html"
    },
    {
      "source": "/processo",
      "destination": "/index.html"
    },
    {
      "source": "/obras",
      "destination": "/index.html"
    },
    {
      "source": "/elegant-fonts",
      "destination": "/Projects/ElegantFonts/index.html"
    },
    {
      "source": "/font-pairing",
      "destination": "/Projects/FontPairing/index.html"
    },
    {
      "source": "/atelier-noir",
      "destination": "/Projects/AtelierNoir/index.html"
    },
    {
      "source": "/elegant-fonts/sobre",
      "destination": "/Projects/ElegantFonts/footer/sobre.html"
    },
    {
      "source": "/elegant-fonts/privacidade",
      "destination": "/Projects/ElegantFonts/footer/privacidade.html"
    },
    {
      "source": "/elegant-fonts/contato",
      "destination": "/Projects/ElegantFonts/footer/contato.html"
    }
  ]
}